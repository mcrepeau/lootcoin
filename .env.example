# Copy this file to .env and fill in the values before running docker compose.

# 32-byte Ed25519 seed for the faucet wallet, as 64 hex characters.
# Generate one by creating a new wallet in the UI and exporting the secret key.
# Fund this address after the chain is running to make the faucet operational.
FAUCET_SECRET_KEY=replace_with_64_char_hex_secret_key

# bech32m address that receives coinbase rewards from the miner (loot1…).
# Generate one by creating a wallet in the UI.
MINER_ADDRESS=replace_with_loot1_address
