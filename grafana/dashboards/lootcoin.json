{
  "title": "Lootcoin",
  "uid": "lootcoin",
  "description": "Chain health, economics, fees, and lottery for the Lootcoin network.",
  "tags": ["lootcoin"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Node",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(lootcoin_chain_height, instance)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Chain Height",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_chain_height{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "—"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Block Time",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_avg_block_time_secs{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "red", "value": 180 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Since Last Block",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_secs_since_last_block{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Difficulty",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_chain_difficulty{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "noValue": "—"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Mempool",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_mempool_size{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 220 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Peers",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_peer_count{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Economics",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Lottery Pot",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_pot_coins{instance=~\"$instance\"}",
          "legendFormat": "pot — {{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Coin Supply",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_circulating_coins{instance=~\"$instance\"}",
          "legendFormat": "circulating — {{instance}}",
          "refId": "A"
        },
        {
          "expr": "lootcoin_pot_coins{instance=~\"$instance\"}",
          "legendFormat": "pot — {{instance}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Fees & Mempool",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Fee Flow (per second)",
      "gridPos": { "x": 0, "y": 14, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(lootcoin_fees_collected_total{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "collected — {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rate(lootcoin_fees_to_miners_total{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "→ miners — {{instance}}",
          "refId": "B"
        },
        {
          "expr": "rate(lootcoin_fees_to_pot_total{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "→ pot — {{instance}}",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Mempool Size",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "lootcoin_mempool_size{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 220 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Lottery",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Lottery Win Rate (per minute)",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(lootcoin_lottery_wins_total{instance=~\"$instance\", tier=\"small\"}[$__rate_interval]) * 60",
          "legendFormat": "small",
          "refId": "A"
        },
        {
          "expr": "rate(lootcoin_lottery_wins_total{instance=~\"$instance\", tier=\"medium\"}[$__rate_interval]) * 60",
          "legendFormat": "medium",
          "refId": "B"
        },
        {
          "expr": "rate(lootcoin_lottery_wins_total{instance=~\"$instance\", tier=\"large\"}[$__rate_interval]) * 60",
          "legendFormat": "large",
          "refId": "C"
        },
        {
          "expr": "rate(lootcoin_lottery_wins_total{instance=~\"$instance\", tier=\"jackpot\"}[$__rate_interval]) * 60",
          "legendFormat": "jackpot",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "small" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#78909C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#42A5F5", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "large" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#AB47BC", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "jackpot" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#EF5350", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Lottery Payouts (coins/second)",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(lootcoin_lottery_payouts_coins_total{instance=~\"$instance\", tier=\"small\"}[$__rate_interval])",
          "legendFormat": "small",
          "refId": "A"
        },
        {
          "expr": "rate(lootcoin_lottery_payouts_coins_total{instance=~\"$instance\", tier=\"medium\"}[$__rate_interval])",
          "legendFormat": "medium",
          "refId": "B"
        },
        {
          "expr": "rate(lootcoin_lottery_payouts_coins_total{instance=~\"$instance\", tier=\"large\"}[$__rate_interval])",
          "legendFormat": "large",
          "refId": "C"
        },
        {
          "expr": "rate(lootcoin_lottery_payouts_coins_total{instance=~\"$instance\", tier=\"jackpot\"}[$__rate_interval])",
          "legendFormat": "jackpot",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "small" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#78909C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#42A5F5", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "large" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#AB47BC", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "jackpot" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#EF5350", "mode": "fixed" } }]
          }
        ]
      }
    }
  ]
}
